{
  "images": {
    "sizes": [320, 640, 800, 1080, 1600, 1920],
    "formats": ["image/avif", "image/webp"],
    "minimumCacheTTL": 31536000,
    "domains": [],
    "remotePatterns": []
  },
  "headers": [
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|gif|svg|ico|woff|woff2|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300, must-revalidate" }
      ]
    },
    {
      "source": "/content/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=60" }
      ]
    }
  ]
}
